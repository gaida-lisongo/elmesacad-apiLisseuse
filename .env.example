# MongoDB Atlas — accepte aussi MONGODB_URI si déjà utilisé localement
MONGO_URI=mongodb+srv://USER:PASS@cluster/dbname?retryWrites=true&w=majority
# Si l’URI ne contient pas le nom de base :
# MONGO_DB_NAME=dbname

CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=
CLOUDINARY_PRESET=
CLOUDINARY_FOLDER=

# Origine exacte du site GitHub Pages (slash final optionnel)
# Exemple : https://owner.github.io/repo-name
CORS_GITHUB_PAGES_ORIGIN=

# Origines supplémentaires, séparées par des virgules
CORS_EXTRA_ORIGINS=

# Débit par appel PATCH /reader/update-progress
CREDITS_PER_PROGRESS_UPDATE=1.15
